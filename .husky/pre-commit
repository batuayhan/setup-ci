npx lint-staged

# Secret leak detection on staged files
if command -v gitleaks &> /dev/null; then
  gitleaks protect --staged --config .gitleaks.toml --verbose 2>/dev/null
  if [ $? -ne 0 ]; then
    echo ""
    echo "🚨 Secret leak detected! Commit blocked."
    echo "If this is a false positive, add it to .gitleaksignore"
    exit 1
  fi
fi
